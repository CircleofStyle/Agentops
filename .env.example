# Resend (email capture + verification)
RESEND_API_KEY=re_xxxxxxxx
RESEND_FROM_EMAIL=Automate This Week <hello@yourdomain.com>
RESEND_AUDIENCE_ID=aud_xxxxxxxx

# Resend inbound webhook (hello@ replies — set after creating webhook in Resend dashboard)
# RESEND_WEBHOOK_SECRET=whsec_xxxxxxxx

# Paperclip API (production webhook → sponsor-outreach-log on NOV-77)
# PAPERCLIP_API_URL=https://your-paperclip-instance/api
# PAPERCLIP_API_KEY=pc_xxxxxxxx

# Public site URL (used in confirmation links)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Gumroad kit product URL (optional — issue-page CTA hidden until set)
# NEXT_PUBLIC_GUMROAD_KIT_URL=https://yourstore.gumroad.com/l/inbox-triage-kit

# Gumroad All Access Pass (€29 one-time — unlocks email-only archive on web)
# NEXT_PUBLIC_GUMROAD_ALL_ACCESS_URL=https://yourstore.gumroad.com/l/all-access-pass
# GUMROAD_ALL_ACCESS_PRODUCT_PERMALINK=all-access-pass
# Gumroad Crown Discipline (€59 one-time — playbook #12 only)
# NEXT_PUBLIC_GUMROAD_CROWN_URL=https://yourstore.gumroad.com/l/crown-discipline
# GUMROAD_CROWN_PRODUCT_PERMALINK=crown-discipline
# GUMROAD_WEBHOOK_SECRET=change-me-in-production
# Gumroad ping URL: https://automatethisweek.com/api/webhooks/gumroad?secret=<GUMROAD_WEBHOOK_SECRET>
# ALL_ACCESS_CODES=launch-friend-001,board-preview-002
# CROWN_ACCESS_CODES=crown-preview-001

# Content pipeline (agent API auth — required in production)
CONTENT_PIPELINE_SECRET=dev-secret-change-me
# Vercel Cron sends Authorization: Bearer $CRON_SECRET — set equal to CONTENT_PIPELINE_SECRET
# CRON_SECRET=dev-secret-change-me

# Growth metrics API (optional override; defaults to CONTENT_PIPELINE_SECRET)
# METRICS_SECRET=dev-metrics-secret

# Monetization KPIs for /api/metrics (optional; override data/monetization.json seed)
# METRICS_AFFILIATE_CLICKS_7D=0
# METRICS_GUMROAD_SALES_30D=0
# METRICS_SPONSOR_REVENUE_TOTAL=0

# Drip sequence (per-subscriber playbook delivery — replaces Tuesday broadcast for new subscribers)
# DRIP_SEQUENCE_ENABLED=true
# DRIP_CADENCE_DAYS=7

# SUBSCRIBE_TOKEN_SECRET=change-me-in-production

# LLM provider — content generation (OpenAI-compatible)
# https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxxxxxxx

# Optional: override default model
# OPENAI_MODEL=gpt-4o-mini

# Affiliate referral URLs (board-provided; defaults to public signup pages until set)
# AFFILIATE_URL_ZAPIER=https://zapier.com/...
# AFFILIATE_URL_MAKE=https://www.make.com/en/register?pc=automatethisweek
# AFFILIATE_URL_OPENAI=https://platform.openai.com/...
# AFFILIATE_URL_CURSOR=https://cursor.com/...
# AFFILIATE_URL_PAPERCLIP=https://paperclip.ing/...

# --- Vercel deployment (set in Vercel/GitHub dashboards, not in repo) ---
# PRODUCTION_URL                    → GitHub Actions secret (public prod URL for health gate)
# VERCEL_AUTOMATION_BYPASS_SECRET   → GitHub Actions secret (if Deployment Protection enabled)
# VERCEL_GIT_COMMIT_SHA             → auto-injected by Vercel at build time
# VERCEL_ENV                        → auto-injected (production | preview | development)
